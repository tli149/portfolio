---
interface Props {
  size?: number;
}
const { size = 36 } = Astro.props;
const inner = size - 6;
const svgSize = size - 12;
---
<div class="ring-hole" style={`width:${size}px;height:${size}px;`}>
  <div class="ring-inner" style={`width:${inner}px;height:${inner}px;`}>
    <svg width={svgSize} height={svgSize} style="opacity:0.15;">
      <defs>
        <pattern id="thumbDiag" width="6" height="6" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
          <line x1="0" y1="0" x2="0" y2="6" stroke="#000" stroke-width="0.5" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#thumbDiag)" />
    </svg>
  </div>
</div>

<style>
  .ring-hole {
    border-radius: 50%;
    border: 1.5px solid #ccc;
    background: #fff;
    flex-shrink: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ring-inner {
    border-radius: 50%;
    background: #f0f0f0;
    border: 0.5px solid #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
