---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const rawProjects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

function slugFrom(id: string): string {
  return id.replace(/\/index$/, '').replace(/^\//, '');
}

type ImgInput = string | { img: string; position?: string; fit?: 'cover' | 'contain' };
type ResolvedImg = { src: string; filename: string; position: string; fit: 'cover' | 'contain' };

function resolveImg(slug: string, input: ImgInput): ResolvedImg {
  const obj = typeof input === 'string' ? { img: input } : input;
  return {
    src: `/projects/${slug}/${obj.img}`,
    filename: obj.img,
    position: obj.position ?? 'center',
    fit: obj.fit ?? 'cover',
  };
}

const projects = rawProjects.map(p => {
  const slug = slugFrom(p.id);
  return {
    ...p,
    slug,
    resolvedImages: {
      hero: resolveImg(slug, p.data.images.hero),
      process: p.data.images.process.map(item => ({
        ...resolveImg(slug, item),
        caption: item.caption,
      })),
      final: resolveImg(slug, p.data.images.final),
    },
  };
});
---
<BaseLayout title="Tianhui Li — Selected Works">
  <div id="app">
    <!-- Overview -->
    <div id="overview">
      <header class="header">
        <h1 class="header-name">Tianhui Li</h1>
        <p class="header-subtitle">Selected Works &nbsp;/&nbsp; [context | architecture]</p>
      </header>

      <div class="project-list">
        {projects.map((project, i) => {
          const tabSide = i % 2 === 0 ? 'left' : 'right';
          const hasLocation = project.data.location && project.data.location !== '—';
          const subtitle = hasLocation
            ? `${project.data.year}  ·  ${project.data.location}`
            : project.data.year;
          return (
            <a
              href={`#project-${project.id}`}
              class:list={['project-row', `tab-${tabSide}`]}
              data-project-id={project.id}
              data-index={i}
              style={`animation-delay: ${0.08 + i * 0.06}s;`}
            >
              <div class="tab-container">
                <span class="tab">{project.data.tags.join('  ·  ')}</span>
              </div>
              <div class="row-body">
                <div class="thumb">
                  <img
                    src={project.resolvedImages.hero.src}
                    alt=""
                    loading="lazy"
                    style={`object-fit: ${project.resolvedImages.hero.fit}; object-position: ${project.resolvedImages.hero.position};`}
                    onerror="this.parentElement.innerHTML='<span>img</span>'"
                  />
                </div>
                <div class="project-info">
                  <h2 class="project-title">{project.data.title}</h2>
                  <p class="project-subtitle">{subtitle}</p>
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <footer class="footer">
        <span>Portfolio — Digest</span>
        <span>About / Contact</span>
      </footer>
    </div>

    <!-- Project View Container -->
    <div id="project-view" class="project-view" aria-hidden="true">
      <div id="project-content"></div>
    </div>
  </div>

  <!-- Project data for client-side rendering -->
  <script define:vars={{ projectsData: projects.map(p => ({
    id: p.id,
    slug: p.slug,
    ...p.data,
    body: p.body,
    resolvedImages: p.resolvedImages,
  })) }}>
    window.__PROJECTS__ = projectsData;
  </script>
  <script src="../scripts/app.ts"></script>
</BaseLayout>

<style>
  #app {
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background: #fff;
    position: relative;
  }

  /* Overview */
  #overview {
    position: absolute;
    inset: 0;
    overflow-y: auto;
    z-index: 1;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background: #fff;
    transition: opacity 0.25s ease, filter 0.25s ease;
  }
  #overview.dimmed {
    opacity: 0.3;
    filter: blur(1.5px);
    overflow: hidden;
  }

  /* Header */
  .header {
    padding: 2.5rem 3rem 1.2rem 5.5rem;
    border-bottom: 1px solid #000;
    animation: fadeDown 0.5s ease both;
  }
  .header-name {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #000;
  }
  .header-subtitle {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: #888;
    margin-top: 0.3rem;
    letter-spacing: 0.04em;
  }

  /* Project list */
  .project-list {
    flex: 1;
    padding-top: 1.5rem;
  }
  .project-row {
    display: block;
    position: relative;
    padding-top: 24px;
    padding-bottom: 1.8rem;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    background: transparent;
    transition: background 0.3s ease, transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    animation: fadeUp 0.4s ease both;
    will-change: transform;
  }
  .project-row:hover {
    background: #fafafa;
    transform: translateY(-10px);
  }
  .project-row:hover .project-title {
    letter-spacing: 0.02em;
  }

  /* Folder tab */
  .tab-container {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 24px;
    pointer-events: none;
  }
  .tab-container::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    border-top: 1px solid #d0d0d0;
  }
  .tab {
    position: absolute;
    bottom: 0;
    height: 22px;
    padding: 0 16px;
    border: 1px solid #d0d0d0;
    border-bottom: none;
    background: #fff;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: #b0b0b0;
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    white-space: nowrap;
  }
  .tab-left .tab {
    left: 5.5rem;
  }
  .tab-right .tab {
    right: 3rem;
  }

  /* Row body (no borders) */
  .row-body {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    padding: 1.5rem 3rem 0 5.5rem;
  }

  .thumb {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: 1px solid #d8d8d8;
    background: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: #c0c0c0;
    flex-shrink: 0;
    overflow: hidden;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-info {
    flex: 1;
  }
  .project-title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 1.05rem;
    color: #000;
    transition: letter-spacing 0.2s ease;
  }
  .project-subtitle {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: #bbb;
    margin-top: 0.35rem;
    letter-spacing: 0.05em;
  }

  /* Footer */
  .footer {
    padding: 1.3rem 3rem 1.3rem 5.5rem;
    border-top: 1px solid #000;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: #ccc;
    letter-spacing: 0.04em;
    animation: fadeIn 0.5s ease 0.4s both;
  }

  /* Project view overlay */
  .project-view {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 100vh;
    z-index: 10;
    pointer-events: none;
    opacity: 0;
    border-top: 1.5px solid #e0e0e0;
  }
  .project-view.active {
    pointer-events: auto;
  }

  /* Animations */
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .header {
      padding: 1.5rem 1.5rem 1rem 1.5rem;
    }
    .row-body {
      padding: 1.2rem 1.5rem 0 1.5rem;
      gap: 1rem;
    }
    .tab-left .tab {
      left: 1.5rem;
    }
    .tab-right .tab {
      right: 1.5rem;
    }
    .footer {
      padding: 1rem 1.5rem;
    }
  }
</style>
